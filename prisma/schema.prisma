generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  STAFF
}

enum MaterialType {
  SOLID_WOOD
  ENGINEERED_WOOD
  ARTIFICIAL_WOOD
  LEATHER
  FABRIC
  METAL
}

enum RoomType {
  LIVING_ROOM
  BEDROOM
  DINING_ROOM
  OFFICE
  OUTDOOR
  KITCHEN
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  MADE_TO_ORDER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED_WON
  CLOSED_LOST
}

enum IssueType {
  BUG
  FEATURE
  CHANGE
  QUESTION
}

model AdminUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(STAFF)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id             String         @id @default(cuid())
  name           String
  slug           String         @unique
  description    String
  price          Decimal        @db.Decimal(10, 2)
  compareAtPrice Decimal?       @db.Decimal(10, 2)
  material       MaterialType
  room           RoomType
  stockStatus    StockStatus    @default(IN_STOCK)
  stockQty       Int            @default(0)
  featured       Boolean        @default(false)
  images         ProductImage[]
  category       Category       @relation(fields: [categoryId], references: [id])
  categoryId     String
  leadItems      LeadItem[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([categoryId])
  @@index([material])
  @@index([room])
  @@index([stockStatus])
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  position  Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  createdAt DateTime @default(now())

  @@index([productId])
}

model Lead {
  id        String     @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String?
  notes     String?
  status    LeadStatus @default(NEW)
  items     LeadItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status])
}

/// Simple key/value store for site-wide settings the admin can change
/// (active landing variant, WhatsApp number, etc.).
model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model LeadItem {
  id        String  @id @default(cuid())
  lead      Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  product   Product @relation(fields: [productId], references: [id])
  productId String

  @@index([leadId])
  @@index([productId])
}

/// Issue / feature / change request raised from the public site. Persisted
/// locally so nothing is lost, then (best-effort) synced to a GitHub issue.
model IssueReport {
  id                String    @id @default(cuid())
  type              IssueType @default(BUG)
  title             String
  body              String
  reporterName      String?
  reporterEmail     String?
  pageUrl           String?
  githubIssueNumber Int?
  githubIssueUrl    String?
  syncError         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([type])
  @@index([createdAt])
}
