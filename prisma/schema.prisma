generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  STAFF
}

enum MaterialType {
  SOLID_WOOD
  ENGINEERED_WOOD
  ARTIFICIAL_WOOD
  LEATHER
  FABRIC
  METAL
}

/// The setting a piece is built for. Values were renamed from the original
/// home-furniture set (living room, bedroom, …) to President's actual
/// market: office, industrial, and hospital furniture. Enum positions are
/// preserved to match the DB after the ALTER TYPE ... RENAME VALUE migration.
enum RoomType {
  RECEPTION
  HEALTHCARE
  CONFERENCE
  OFFICE
  INDUSTRIAL
  WORKSPACE
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  MADE_TO_ORDER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED_WON
  CLOSED_LOST
}

enum IssueType {
  BUG
  FEATURE
  CHANGE
  QUESTION
}

enum OrderStatus {
  PLACED
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  SSLCOMMERZ
  COD
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

model AdminUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(STAFF)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id               String         @id @default(cuid())
  name             String
  slug             String         @unique
  description      String
  price            Decimal        @db.Decimal(10, 2)
  compareAtPrice   Decimal?       @db.Decimal(10, 2)
  material         MaterialType
  room             RoomType
  color            String?
  dimensions       String?
  deliveryEstimate String?
  stockStatus      StockStatus    @default(IN_STOCK)
  stockQty         Int            @default(0)
  featured         Boolean        @default(false)
  viewCount        Int            @default(0)
  images           ProductImage[]
  category         Category       @relation(fields: [categoryId], references: [id])
  categoryId       String
  leadItems        LeadItem[]
  orderItems       OrderItem[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([categoryId])
  @@index([material])
  @@index([room])
  @@index([stockStatus])
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  position  Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  createdAt DateTime @default(now())

  @@index([productId])
}

model Lead {
  id        String     @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String?
  notes     String?
  status    LeadStatus @default(NEW)
  items     LeadItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status])
}

/// Simple key/value store for site-wide settings the admin can change
/// (active landing variant, WhatsApp number, etc.).
model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model LeadItem {
  id        String  @id @default(cuid())
  lead      Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  product   Product @relation(fields: [productId], references: [id])
  productId String

  @@index([leadId])
  @@index([productId])
}

/// Issue / feature / change request raised from the public site. Persisted
/// locally so nothing is lost, then (best-effort) synced to a GitHub issue.
model IssueReport {
  id                String    @id @default(cuid())
  type              IssueType @default(BUG)
  title             String
  body              String
  reporterName      String?
  reporterEmail     String?
  pageUrl           String?
  githubIssueNumber Int?
  githubIssueUrl    String?
  syncError         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([type])
  @@index([createdAt])
}

model Customer {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  phone        String?
  /// Null for customer records created from a guest order; they can set a
  /// password later to "claim" the account.
  passwordHash String?
  addresses    Address[]
  orders       Order[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Address {
  id            String   @id @default(cuid())
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId    String
  label         String?
  recipientName String
  phone         String
  line1         String
  line2         String?
  city          String
  area          String?
  postCode      String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([customerId])
}

/// A placed order. Shipping details are denormalized (ship*) so later
/// address edits never rewrite order history.
model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique
  customer      Customer?     @relation(fields: [customerId], references: [id])
  customerId    String?
  guestName     String?
  guestEmail    String?
  guestPhone    String?
  shipName      String
  shipPhone     String
  shipLine1     String
  shipLine2     String?
  shipCity      String
  shipArea      String?
  shipPostCode  String?
  items         OrderItem[]
  payments      Payment[]
  subtotal      Decimal       @db.Decimal(10, 2)
  shippingFee   Decimal       @default(0) @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  currency      String        @default("BDT")
  status        OrderStatus   @default(PLACED)
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

/// Snapshot of a product's name/price at order time, so later catalog
/// edits never alter past orders.
model OrderItem {
  id            String  @id @default(cuid())
  order         Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId       String
  product       Product @relation(fields: [productId], references: [id])
  productId     String
  nameSnapshot  String
  priceSnapshot Decimal @db.Decimal(10, 2)
  qty           Int
  lineTotal     Decimal @db.Decimal(10, 2)

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id           String        @id @default(cuid())
  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  gateway      PaymentMethod
  gatewayTxnId String?
  valId        String?
  amount       Decimal       @db.Decimal(10, 2)
  status       PaymentStatus @default(PENDING)
  rawPayload   Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([orderId])
  @@index([gatewayTxnId])
}
