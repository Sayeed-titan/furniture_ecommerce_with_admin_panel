# --- Database (Supabase Postgres) ---
# Get these from your Supabase project: Project Settings > Database > Connection string
# DATABASE_URL uses the pooled connection (port 6543), DIRECT_URL uses the direct connection (port 5432)
# Prisma migrations need DIRECT_URL; the app uses DATABASE_URL at runtime.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# --- Auth.js (admin panel login) ---
# Generate with: npx auth secret
AUTH_SECRET="replace-with-a-random-32-byte-secret"

# Full URL of the deployed site (used by Auth.js). For local dev leave as-is.
NEXTAUTH_URL="http://localhost:3000"

# --- Supabase Storage (product image uploads) ---
# Optional: when unset, the admin product form falls back to pasting an image URL.
# Create a PUBLIC bucket named "product-images" (or set SUPABASE_STORAGE_BUCKET).
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="replace-with-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"
SUPABASE_STORAGE_BUCKET="product-images"

# --- GitHub issue integration (website "Report an issue" -> opens a GitHub issue) ---
# Optional: when unset, reports are still saved in the admin panel (Issues tab),
# just not pushed to GitHub. Use a fine-grained PAT with Issues: read & write.
GITHUB_TOKEN="replace-with-a-fine-grained-PAT-with-issues:write"
GITHUB_REPO_OWNER="sayeed-titan"
GITHUB_REPO_NAME="furniture_ecommerce_with_admin_panel"

# --- Email notifications (new leads + issue reports) ---
# Optional: when unset, notifications are silently skipped (nothing breaks).
# Uses Resend (https://resend.com). EMAIL_FROM must be a verified sender.
RESEND_API_KEY="replace-with-resend-api-key"
EMAIL_FROM="Woodcraft Furniture <alerts@yourdomain.com>"
NOTIFY_EMAIL="you@yourbusiness.com"

# --- Payments (SSLCommerz) ---
# Optional: when unset, only Cash on Delivery is available at checkout.
# Sandbox credentials are self-serve: https://developer.sslcommerz.com/registration/
SSLCOMMERZ_STORE_ID="replace-with-sslcommerz-store-id"
SSLCOMMERZ_STORE_PASSWORD="replace-with-sslcommerz-store-password"
SSLCOMMERZ_SANDBOX="true"
